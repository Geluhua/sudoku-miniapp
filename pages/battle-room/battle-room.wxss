.battle-room-page { min-height: 100vh; padding: 16rpx; }

.waiting-area { padding: 160rpx 0; }
.waiting-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.waiting-title { font-size: 34rpx; font-weight: 600; margin-bottom: 16rpx; }
.waiting-code {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--accent);
  letter-spacing: 8rpx;
  font-family: monospace;
}
.waiting-tip { font-size: 24rpx; }

.battle-header {
  padding: 24rpx 32rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
}
.player-label { font-size: 24rpx; color: var(--text-secondary); }
.player-time { font-size: 36rpx; font-weight: 700; font-family: monospace; color: var(--accent); }
.player-status { font-size: 22rpx; margin-top: 4rpx; }
.vs-text { font-size: 32rpx; font-weight: 700; color: var(--pink); }

.board-container { display: flex; justify-content: center; margin: 20rpx 0; }
.board {
  display: grid;
  grid-template-columns: repeat(9, 1fr);
  gap: 2rpx;
  background: var(--border-color);
  border: 4rpx solid var(--border-color);
  border-radius: 8rpx;
  aspect-ratio: 1;
  max-width: 580rpx;
  width: 100%;
}
.cell {
  aspect-ratio: 1;
  background: var(--bg-cell);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}
.cell.given { background: var(--bg-card); }
.cell.selected { background: var(--bg-cell-selected); box-shadow: inset 0 0 0 3rpx var(--accent); }
.cell.related { background: var(--bg-cell-related); }
.cell.error { color: var(--error); }

.number-pad { padding: 12rpx 0; }
.num-row { justify-content: center; gap: 8rpx; margin-bottom: 12rpx; }
.num-key {
  width: 62rpx; height: 62rpx;
  border-radius: 12rpx;
  background: var(--bg-card);
  border: 2rpx solid var(--border-color);
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; font-weight: 700;
  color: var(--text-primary);
}
.num-key.active { border-color: var(--accent); background: var(--bg-cell-selected); color: var(--accent); }
.num-key.action { width: auto; font-size: 24rpx; background: var(--bg-secondary); }
.num-key.erase { color: var(--error); border-color: var(--error); }

.result-area { padding: 120rpx 0; }
.result-icon { font-size: 100rpx; margin-bottom: 20rpx; }
.result-title { font-size: 42rpx; font-weight: 700; margin-bottom: 24rpx; }
.result-detail { font-size: 28rpx; margin-top: 8rpx; }
