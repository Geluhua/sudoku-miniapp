.index-page {
  padding: 20rpx 24rpx 40rpx;
  min-height: 100vh;
}

.header-area { margin-bottom: 24rpx; }

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--bg-cell);
  border: 2rpx solid var(--accent);
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
}

/* 数独值卡片 */
.value-card {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #16213e, #1a2744);
  border: 1rpx solid var(--accent-dim);
}

.value-icon { font-size: 36rpx; }
.value-label { font-size: 28rpx; color: var(--text-secondary); }
.value-count {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--gold);
}

.value-detail { font-size: 24rpx; }
.value-actions button { font-size: 24rpx; }

/* 阶段选择 */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin: 12rpx 0 16rpx;
}

.stages-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.stage-card {
  position: relative;
  overflow: hidden;
  padding: 28rpx;
}

.stage-name {
  font-size: 32rpx;
  font-weight: 700;
}

.stage-badge {
  font-size: 22rpx;
  background: var(--accent-dim);
  color: #0f0f23;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.stage-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.stage-progress { margin-top: 12rpx; }

.progress-text {
  font-size: 22rpx;
  color: var(--text-accent);
}

.progress-bar {
  height: 8rpx;
  background: var(--bg-cell);
  border-radius: 4rpx;
  margin-top: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent-dim), var(--accent));
  border-radius: 4rpx;
  transition: width 0.3s;
}

.lock-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
}

.lock-desc {
  color: var(--text-secondary);
  font-size: 24rpx;
  text-align: center;
  padding: 20rpx;
}

/* 底部入口 */
.entries-area {
  margin-top: 32rpx;
  padding-bottom: 40rpx;
}

.entry-btn {
  padding: 28rpx 16rpx;
  flex-direction: column;
  gap: 12rpx;
}

.entry-icon { font-size: 40rpx; }
.entry-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}
