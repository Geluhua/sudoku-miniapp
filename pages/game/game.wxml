<view class="game-page">
  <!-- 顶部信息栏 -->
  <view class="game-header flex-between">
    <view class="header-item flex-col">
      <text class="header-label">用时</text>
      <text class="header-value timer">{{timerDisplay}}</text>
    </view>
    <view class="header-item flex-col">
      <text class="header-label">难度</text>
      <text class="header-value">{{difficultyName}}</text>
    </view>
    <view class="header-item flex-col">
      <text class="header-label">试错</text>
      <text class="header-value {{mistakesLeft <= 1 ? 'text-error' : ''}}">
        {{mistakesLeft}}/3
      </text>
    </view>
  </view>

  <!-- 棋盘 -->
  <view class="board-container">
    <view class="board" style="--size: {{size}}; --box-rows: {{boxRows}}; --box-cols: {{boxCols}}">
      <view 
        class="cell {{cell.isGiven ? 'given' : ''}} {{cell.isSelected ? 'selected' : ''}} {{cell.isRelated ? 'related' : ''}} {{cell.isSameNum ? 'same-num' : ''}} {{cell.isError ? 'error' : ''}}"
        wx:for="{{cells}}" wx:for-item="cell" wx:key="index"
        data-index="{{index}}"
        bindtap="selectCell"
      >
        <text class="cell-text" wx:if="{{cell.value}}">{{cell.value}}</text>
        <!-- 宫格边界 -->
        <view class="border-right" wx:if="{{(index + 1) % boxCols === 0 && (index + 1) % size !== 0}}"></view>
        <view class="border-bottom" wx:if="{{Math.floor(index / size) % boxRows === boxRows - 1 && Math.floor(index / size) !== size - 1}}"></view>
      </view>
    </view>
  </view>

  <!-- 数字输入区 -->
  <view class="number-pad">
    <view class="num-row flex-row">
      <view 
        class="num-key {{selectedNum === item ? 'active' : ''}}"
        wx:for="{{numbers}}" wx:key="index"
        data-num="{{item}}"
        bindtap="inputNumber"
      >
        <text>{{item}}</text>
      </view>
    </view>
    <view class="num-actions flex-row gap-12">
      <view class="num-key action erase flex-1" bindtap="eraseCell">
        <text>擦除</text>
      </view>
      <view class="num-key action hint flex-1" bindtap="useHint">
        <text>提示</text>
      </view>
    </view>
  </view>

  <!-- 音效控制 -->
  <view class="sound-controls flex-row gap-20">
    <view class="sound-item flex-row gap-8" bindtap="toggleMusic">
      <text class="sound-icon">{{musicEnabled ? '🎵' : '🔇'}}</text>
      <text class="sound-label">音乐</text>
    </view>
    <view class="sound-item flex-row gap-8" bindtap="toggleSound">
      <text class="sound-icon">{{soundEnabled ? '🔊' : '🔇'}}</text>
      <text class="sound-label">音效</text>
    </view>
  </view>

  <!-- 完成弹窗 -->
  <view class="modal-mask" wx:if="{{showComplete}}" bindtap="closeModal">
    <view class="modal-card card" catchtap="nop">
      <text class="modal-title">{{modalTitle}}</text>
      <view class="modal-body flex-col gap-12">
        <text class="modal-time">完成时间: {{timerDisplay}}</text>
        <text class="modal-detail">标准时间: {{formatTime(timeLimit)}}</text>
        <text class="modal-result {{isPassed ? 'text-accent' : 'text-error'}}">
          {{isPassed ? '达标! ✔' : '超时,未达标 ✘'}}
        </text>
      </view>
      <view class="modal-actions flex-row gap-16">
        <button class="btn-secondary flex-1" bindtap="collectPuzzle">收藏题目</button>
        <button class="btn-primary flex-1" bindtap="continueGame">继续</button>
      </view>
    </view>
  </view>
</view>
