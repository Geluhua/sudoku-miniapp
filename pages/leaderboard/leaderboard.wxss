.lb-page { min-height: 100vh; padding: 24rpx 28rpx; }

.tabs {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  border-bottom: 3rpx solid transparent;
  transition: all var(--transition-fast);
}

.tab.active {
  color: var(--accent);
  border-bottom-color: var(--accent);
  font-weight: 600;
  background: var(--accent-soft);
}

.rank-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rank-item {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  transition: border-color var(--transition-fast);
}

.rank-badge {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: 700;
}

.rank-1 { background: rgba(252, 211, 77, 0.2); color: var(--gold); }
.rank-2 { background: rgba(192, 192, 192, 0.2); color: #d1d5db; }
.rank-3 { background: rgba(205, 127, 50, 0.2); color: #f59e0b; }
.rank-other { background: var(--bg-secondary); color: var(--text-secondary); }

.rank-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--bg-secondary);
  border: 2rpx solid var(--border-color);
}

.rank-name {
  font-size: 28rpx;
  font-weight: 600;
}

.rank-stats { align-items: flex-end; }
.rank-stat-main {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--accent);
}
.rank-stat-sub {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.loading-area, .empty-area {
  padding: 120rpx 0;
}
