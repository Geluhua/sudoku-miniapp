.review-page { min-height: 100vh; padding: 20rpx 24rpx; }

.review-info { margin-bottom: 20rpx; }
.review-stage { font-size: 30rpx; font-weight: 600; margin-bottom: 4rpx; }
.review-step-indicator { font-size: 28rpx; font-weight: 600; }

.board-container {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.board {
  display: grid;
  grid-template-columns: repeat(var(--size), 1fr);
  grid-template-rows: repeat(var(--size), 1fr);
  gap: 2rpx;
  background: var(--border-color);
  border: 4rpx solid var(--border-color);
  border-radius: 8rpx;
  aspect-ratio: 1;
  max-width: 560rpx;
  width: 100%;
}

.cell {
  aspect-ratio: 1;
  background: var(--bg-cell);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
}

.cell.given { background: var(--bg-card); }
.cell.new-fill { 
  background: var(--bg-cell-selected);
  color: var(--accent);
  animation: popIn 0.3s;
}
.cell.highlight { color: var(--accent); }

@keyframes popIn {
  0% { transform: scale(0.8); }
  100% { transform: scale(1); }
}

.progress-container { margin: 16rpx 0; }
.progress-track {
  height: 8rpx;
  background: var(--bg-cell);
  border-radius: 4rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.review-controls { margin-top: 24rpx; }
.review-restart { gap: 16rpx; }
