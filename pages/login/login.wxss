.login-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(165deg, #0c1222 0%, #141c30 50%, #1a2540 100%);
  padding: 40rpx;
}

.login-container {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-grid {
  display: grid;
  grid-template-columns: repeat(4, 70rpx);
  grid-template-rows: repeat(4, 70rpx);
  gap: 4rpx;
  margin-bottom: 40rpx;
  padding: 12rpx;
  background: var(--border-strong);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-md), var(--shadow-glow);
}

.logo-cell {
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-cell);
  border-radius: 6rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--accent);
}

.logo-cell:nth-child(odd) {
  color: var(--text-primary);
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--accent);
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
  text-shadow: 0 0 32rpx rgba(94, 234, 212, 0.3);
}

.app-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #2dd4bf 0%, #5eead4 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(94, 234, 212, 0.3);
}

.login-btn-hover {
  transform: scale(0.98);
  opacity: 0.92;
}

.login-btn-text {
  color: #0c1222;
  font-size: 32rpx;
  font-weight: 600;
}

.guest-entry {
  padding: 16rpx 0;
  margin-bottom: 40rpx;
}

.guest-text {
  color: var(--text-secondary);
  font-size: 26rpx;
}

.privacy-tip {
  font-size: 22rpx;
  color: var(--text-secondary);
  opacity: 0.6;
  text-align: center;
}
