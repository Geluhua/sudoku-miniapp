.login-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #0f0f23 0%, #1a1a2e 50%, #16213e 100%);
  padding: 40rpx;
}

.login-container {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-grid {
  display: grid;
  grid-template-columns: repeat(4, 70rpx);
  grid-template-rows: repeat(4, 70rpx);
  gap: 4rpx;
  margin-bottom: 40rpx;
}

.logo-cell {
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-cell);
  border-radius: 8rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-accent);
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-accent);
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.app-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160, #06ad56);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.login-btn-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.guest-entry {
  padding: 16rpx 0;
  margin-bottom: 40rpx;
}

.guest-text {
  color: var(--text-secondary);
  font-size: 26rpx;
}

.privacy-tip {
  font-size: 22rpx;
  color: #555;
  text-align: center;
}
