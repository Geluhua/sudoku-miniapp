/* 全局样式变量与通用类 */
page {
  --bg-primary: #0c1222;
  --bg-secondary: #141c30;
  --bg-card: #1a2540;
  --bg-elevated: #212d4a;
  --bg-cell: #1e2a45;
  --bg-cell-selected: rgba(94, 234, 212, 0.22);
  --bg-cell-related: rgba(94, 234, 212, 0.09);
  --bg-cell-same-num: rgba(167, 139, 250, 0.14);
  --text-primary: #eef2f8;
  --text-secondary: #8b9cb8;
  --text-accent: #5eead4;
  --text-error: #fca5a5;
  --text-gold: #fcd34d;
  --border-color: #2a3654;
  --border-strong: #3d4f72;
  --accent: #5eead4;
  --accent-dim: #2dd4bf;
  --accent-soft: rgba(94, 234, 212, 0.12);
  --error: #f87171;
  --error-soft: rgba(248, 113, 113, 0.15);
  --warning: #fbbf24;
  --warning-soft: rgba(251, 191, 36, 0.15);
  --success: #4ade80;
  --gold: #fcd34d;
  --purple: #a78bfa;
  --pink: #fb7185;
  --stage-four: #5eead4;
  --stage-six: #a78bfa;
  --stage-nine: #fb7185;
  --shadow-sm: 0 4rpx 16rpx rgba(0, 0, 0, 0.28);
  --shadow-md: 0 8rpx 32rpx rgba(0, 0, 0, 0.38);
  --shadow-glow: 0 0 28rpx rgba(94, 234, 212, 0.12);
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 20rpx;
  --radius-xl: 24rpx;
  --transition-fast: 0.15s ease;
  --transition-normal: 0.25s ease;
  background: linear-gradient(165deg, #0c1222 0%, #101829 45%, #0f1628 100%);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  min-height: 100vh;
}

.btn-primary {
  background: linear-gradient(135deg, #2dd4bf 0%, #5eead4 100%);
  color: #0c1222;
  border: none;
  border-radius: var(--radius-md);
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(94, 234, 212, 0.25);
  transition: transform var(--transition-fast), opacity var(--transition-fast);
}
.btn-primary[disabled] { opacity: 0.4; }
.btn-primary-hover {
  transform: scale(0.97);
  opacity: 0.92;
}

.btn-secondary {
  background: var(--bg-elevated);
  color: var(--text-primary);
  border: 2rpx solid var(--border-strong);
  border-radius: var(--radius-md);
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform var(--transition-fast), border-color var(--transition-fast);
}
.btn-secondary-hover {
  transform: scale(0.97);
  border-color: var(--accent);
}

.btn-danger {
  background: linear-gradient(135deg, #ef4444, #f87171);
  color: #fff;
  border: none;
  border-radius: var(--radius-md);
  padding: 18rpx 36rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin: 16rpx 0;
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  transition: transform var(--transition-fast), border-color var(--transition-fast), box-shadow var(--transition-fast);
}
.card-hover {
  transform: scale(0.985);
  border-color: var(--border-strong);
}

.card-interactive {
  transition: transform var(--transition-fast), border-color var(--transition-fast), box-shadow var(--transition-fast);
}
.card-interactive-hover {
  transform: translateY(-2rpx);
  border-color: rgba(94, 234, 212, 0.35);
  box-shadow: var(--shadow-md), var(--shadow-glow);
}

.locked { filter: grayscale(70%); opacity: 0.55; }

.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }
.gap-8 { gap: 8rpx; }
.gap-12 { gap: 12rpx; }
.gap-16 { gap: 16rpx; }
.gap-20 { gap: 20rpx; }
.text-center { text-align: center; }
.text-accent { color: var(--accent); }
.text-error { color: var(--error); }
.text-gold { color: var(--gold); }
.text-secondary { color: var(--text-secondary); }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mb-16 { margin-bottom: 16rpx; }
.px-24 { padding-left: 24rpx; padding-right: 24rpx; }

/* 通用棋盘样式 */
.sudoku-board {
  display: grid;
  gap: 2rpx;
  background: var(--border-strong);
  border: 4rpx solid var(--border-strong);
  border-radius: var(--radius-sm);
  aspect-ratio: 1;
  width: 100%;
  box-shadow: var(--shadow-md), inset 0 0 0 1rpx rgba(255, 255, 255, 0.04);
}

.sudoku-cell {
  position: relative;
  aspect-ratio: 1;
  background: var(--bg-cell);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  transition: background var(--transition-fast), color var(--transition-fast), box-shadow var(--transition-fast);
}

.sudoku-cell.given {
  background: var(--bg-secondary);
  font-weight: 700;
}

.sudoku-cell.selected {
  background: var(--bg-cell-selected) !important;
  box-shadow: inset 0 0 0 3rpx var(--accent);
}

.sudoku-cell.related { background: var(--bg-cell-related); }
.sudoku-cell.same-num { background: var(--bg-cell-same-num); }
.sudoku-cell.error { color: var(--error); animation: cell-shake 0.35s ease; }

.sudoku-cell-press {
  background: var(--bg-cell-selected) !important;
  opacity: 0.85;
}

@keyframes cell-shake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-6rpx); }
  40% { transform: translateX(6rpx); }
  60% { transform: translateX(-4rpx); }
  80% { transform: translateX(4rpx); }
}
